{
  "version": 2,
  "buildCommand": "flutter build web --release --no-tree-shake-icons",
  "outputDirectory": "build/web",
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_ANON_KEY": "@supabase_anon_key"
  },
  "routes": [
    {
      "src": "/(.*)\\.",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
